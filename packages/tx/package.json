{
    "name": "@polkadot-apps/tx",
    "description": "Transaction submission, lifecycle watching, and dev signers for Polkadot chains",
    "version": "0.2.11",
    "type": "module",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js"
        }
    },
    "files": ["dist"],
    "sideEffects": false,
    "publishConfig": {
        "access": "public"
    },
    "scripts": {
        "build": "tsc -p tsconfig.json",
        "clean": "rm -rf dist"
    },
    "dependencies": {
        "polkadot-api": "catalog:",
        "@polkadot-labs/hdkd-helpers": "catalog:",
        "@polkadot-apps/keys": "workspace:*",
        "@polkadot-apps/logger": "workspace:*"
    },
    "devDependencies": {
        "typescript": "catalog:"
    }
}
