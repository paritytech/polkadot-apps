{
    "name": "@polkadot-apps/storage",
    "description": "Key-value storage abstraction with automatic host/browser backend detection",
    "version": "0.2.3",
    "type": "module",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "source": "./src/index.ts",
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js"
        }
    },
    "files": ["dist"],
    "sideEffects": false,
    "publishConfig": {
        "access": "public"
    },
    "scripts": {
        "build": "tsc -p tsconfig.json",
        "clean": "rm -rf dist"
    },
    "dependencies": {
        "@polkadot-apps/host": "workspace:*",
        "@polkadot-apps/logger": "workspace:*",
        "dexie": "catalog:"
    },
    "devDependencies": {
        "typescript": "catalog:"
    }
}
