{
    "name": "@polkadot-apps/chain-client",
    "description": "Multi-chain Polkadot API client with typed access to Asset Hub, Bulletin, and Individuality chains",
    "version": "0.3.6",
    "type": "module",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "source": "./src/index.ts",
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js"
        }
    },
    "files": ["dist"],
    "sideEffects": false,
    "publishConfig": {
        "access": "public"
    },
    "scripts": {
        "build": "tsc -p tsconfig.json",
        "clean": "rm -rf dist"
    },
    "dependencies": {
        "@polkadot-apps/descriptors": "workspace:*",
        "@polkadot-apps/host": "workspace:*",
        "@polkadot-api/sdk-ink": "catalog:",
        "polkadot-api": "catalog:"
    },
    "peerDependencies": {
        "@novasamatech/product-sdk": "catalog:"
    },
    "peerDependenciesMeta": {
        "@novasamatech/product-sdk": {
            "optional": true
        }
    },
    "devDependencies": {
        "typescript": "catalog:"
    }
}
