{
    "name": "@polkadot-apps/chain-client",
    "description": "Multi-chain Polkadot API client — BYOD descriptors or built-in presets for Asset Hub, Bulletin, and Individuality",
    "version": "2.0.0",
    "type": "module",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "source": "./src/index.ts",
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js"
        }
    },
    "files": ["dist"],
    "sideEffects": false,
    "publishConfig": {
        "access": "public"
    },
    "scripts": {
        "build": "tsc -p tsconfig.json",
        "clean": "rm -rf dist"
    },
    "dependencies": {
        "@polkadot-apps/descriptors": "workspace:*",
        "@polkadot-apps/host": "workspace:*",
        "polkadot-api": "catalog:"
    },
    "devDependencies": {
        "typescript": "catalog:"
    }
}
