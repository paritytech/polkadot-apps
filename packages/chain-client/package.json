{
    "name": "@polkadot-apps/chain-client",
    "version": "0.1.5",
    "type": "module",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "source": "./src/index.ts",
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js"
        },
        "./testing": {
            "types": "./dist/testing.d.ts",
            "import": "./dist/testing.js"
        }
    },
    "files": ["dist"],
    "publishConfig": {
        "access": "public"
    },
    "scripts": {
        "build": "tsc -p tsconfig.json",
        "clean": "rm -rf dist"
    },
    "dependencies": {
        "@polkadot-apps/descriptors": "workspace:*",
        "polkadot-api": "catalog:"
    },
    "peerDependencies": {
        "@novasamatech/product-sdk": ">=0.1.0"
    },
    "peerDependenciesMeta": {
        "@novasamatech/product-sdk": {
            "optional": true
        }
    },
    "optionalDependencies": {
        "@polkadot-api/sdk-ink": "^0.6.2",
        "@polkadot-api/known-chains": "*"
    },
    "devDependencies": {
        "typescript": "catalog:"
    }
}
