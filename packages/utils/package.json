{
    "name": "@polkadot-apps/utils",
    "description": "Encoding utilities and token formatting for the @polkadot-apps ecosystem",
    "version": "0.2.0",
    "type": "module",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "source": "./src/index.ts",
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js"
        }
    },
    "files": ["dist"],
    "sideEffects": false,
    "publishConfig": {
        "access": "public"
    },
    "scripts": {
        "build": "tsc -p tsconfig.json",
        "clean": "rm -rf dist"
    },
    "dependencies": {
        "@noble/hashes": "catalog:",
        "@polkadot-apps/logger": "workspace:*"
    },
    "devDependencies": {
        "typescript": "catalog:"
    }
}
