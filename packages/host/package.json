{
    "name": "@polkadot-apps/host",
    "description": "Host container detection and storage access for Polkadot Desktop and Mobile environments",
    "version": "0.4.0",
    "type": "module",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "source": "./src/index.ts",
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js"
        }
    },
    "files": ["dist"],
    "sideEffects": false,
    "publishConfig": {
        "access": "public"
    },
    "scripts": {
        "build": "tsc -p tsconfig.json",
        "clean": "rm -rf dist"
    },
    "dependencies": {
        "polkadot-api": "catalog:"
    },
    "peerDependencies": {
        "@novasamatech/product-sdk": ">=0.1.0"
    },
    "peerDependenciesMeta": {
        "@novasamatech/product-sdk": {
            "optional": true
        }
    },
    "devDependencies": {
        "@novasamatech/product-sdk": "catalog:",
        "typescript": "catalog:"
    }
}
