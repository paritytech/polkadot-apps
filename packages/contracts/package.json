{
    "name": "@polkadot-apps/contracts",
    "description": "Typed contract interactions for CDM-managed contracts on Polkadot Asset Hub",
    "version": "0.1.0",
    "type": "module",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "source": "./src/index.ts",
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js"
        },
        "./codegen": {
            "source": "./src/codegen.ts",
            "types": "./dist/codegen.d.ts",
            "import": "./dist/codegen.js"
        }
    },
    "files": ["dist"],
    "sideEffects": false,
    "publishConfig": {
        "access": "public"
    },
    "scripts": {
        "build": "tsc -p tsconfig.json",
        "clean": "rm -rf dist"
    },
    "dependencies": {
        "@polkadot-api/sdk-ink": "catalog:",
        "@polkadot-apps/tx": "workspace:*",
        "polkadot-api": "catalog:"
    },
    "devDependencies": {
        "typescript": "catalog:"
    }
}
