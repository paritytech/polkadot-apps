{
    "name": "@polkadot-apps/bulletin",
    "description": "TypeScript SDK for uploading and retrieving data on the Polkadot Bulletin Chain",
    "version": "0.4.4",
    "type": "module",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "source": "./src/index.ts",
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js"
        }
    },
    "files": ["dist"],
    "sideEffects": false,
    "publishConfig": {
        "access": "public"
    },
    "scripts": {
        "build": "tsc -p tsconfig.json",
        "clean": "rm -rf dist"
    },
    "dependencies": {
        "@polkadot-apps/chain-client": "workspace:*",
        "@polkadot-apps/descriptors": "workspace:*",
        "@polkadot-apps/host": "workspace:*",
        "@polkadot-apps/logger": "workspace:*",
        "@polkadot-apps/tx": "workspace:*",
        "@polkadot-apps/utils": "workspace:*",
        "multiformats": "catalog:",
        "polkadot-api": "catalog:"
    },
    "peerDependencies": {
        "@novasamatech/product-sdk": ">=0.1.0"
    },
    "peerDependenciesMeta": {
        "@novasamatech/product-sdk": {
            "optional": true
        }
    },
    "devDependencies": {
        "@novasamatech/product-sdk": "catalog:",
        "typescript": "catalog:"
    }
}
