{
    "name": "@polkadot-apps/descriptors",
    "description": "Pre-generated Polkadot API descriptors for Asset Hub, Bulletin, and Individuality chains",
    "version": "0.1.7",
    "type": "module",
    "main": "./generated/dist/index.mjs",
    "types": "./generated/dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./generated/dist/index.d.ts",
            "module": "./generated/dist/index.mjs",
            "import": "./generated/dist/index.mjs"
        },
        "./polkadot-asset-hub": {
            "types": "./generated/dist/polkadot_asset_hub.d.ts",
            "import": "./generated/dist/polkadot-asset-hub.mjs"
        },
        "./kusama-asset-hub": {
            "types": "./generated/dist/kusama_asset_hub.d.ts",
            "import": "./generated/dist/kusama-asset-hub.mjs"
        },
        "./paseo-asset-hub": {
            "types": "./generated/dist/paseo_asset_hub.d.ts",
            "import": "./generated/dist/paseo-asset-hub.mjs"
        },
        "./bulletin": {
            "types": "./generated/dist/bulletin.d.ts",
            "import": "./generated/dist/bulletin.mjs"
        },
        "./individuality": {
            "types": "./generated/dist/individuality.d.ts",
            "import": "./generated/dist/individuality.mjs"
        },
        "./package.json": "./package.json"
    },
    "sideEffects": false,
    "files": [
        "generated/dist"
    ],
    "publishConfig": {
        "access": "public"
    },
    "scripts": {
        "generate": "bash scripts/generate.sh",
        "build": "test -d generated/dist || papi",
        "clean": "rm -rf generated"
    },
    "peerDependencies": {
        "polkadot-api": ">=1.23.0"
    },
    "devDependencies": {
        "polkadot-api": "catalog:"
    },
    "dependencies": {
        "@polkadot-api/descriptors": "file:generated"
    }
}
