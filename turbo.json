{
    "$schema": "https://turbo.build/schema.json",
    "globalDependencies": ["vitest.config.ts"],
    "tasks": {
        "build": {
            "dependsOn": ["^build"],
            "outputs": ["dist/**"]
        },
        "@polkadot-apps/descriptors#build": {
            "dependsOn": ["^build"],
            "outputs": ["generated/dist/**"]
        },
        "@polkadot-apps/cli#build": {
            "dependsOn": ["^build"],
            "outputs": []
        },
        "dev": {
            "cache": false,
            "persistent": true
        },
        "test": {
            "dependsOn": ["^build"]
        },
        "clean": {
            "cache": false
        }
    }
}
