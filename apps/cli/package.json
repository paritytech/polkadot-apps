{
    "name": "@polkadot-apps/cli",
    "description": "CLI for building and managing Polkadot apps",
    "version": "0.0.1",
    "private": true,
    "type": "module",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "bin": {
        "polkadot-apps": "./dist/index.js"
    },
    "exports": {
        ".": {
            "source": "./src/index.ts",
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js"
        }
    },
    "files": ["dist"],
    "sideEffects": false,
    "scripts": {
        "build": "tsc -p tsconfig.json",
        "clean": "rm -rf dist"
    },
    "dependencies": {},
    "devDependencies": {
        "typescript": "catalog:"
    }
}
